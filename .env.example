# ==============================================================================
#  agent-bot.uz — Environment Variables
# ==============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
BOT_TOKEN=
OPENAI_API_KEY=
ADMIN_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev:   postgresql+asyncpg://bankbot:bankbot@localhost:5432/bankbot
# Production:  postgresql+asyncpg://bankbot:bankbot@db:5432/bankbot
#              (overridden in docker-compose.prod.yml, no need to change)
DATABASE_URL=postgresql+asyncpg://bankbot:bankbot@localhost:5432/bankbot
POSTGRES_USER=bankbot
POSTGRES_PASSWORD=bankbot
POSTGRES_DB=bankbot

# ── OpenAI / LLM ────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # custom OpenAI-compatible endpoint
# LOCAL_AGENT_INTENT_LLM_MODEL= # override model for agent

# ── LLM provider switch (OpenAI vs Qwen/Together AI) ─────────────────────────
# USE_GPT=true (default) → chat + language detector use OpenAI (OPENAI_MODEL).
# USE_GPT=false          → chat + language detector use Qwen via Together AI.
# Either way, FAQ embeddings (semantic search) ALWAYS use OPENAI_API_KEY — keep
# it set even on Qwen, or set FAQ_EMBEDDING_ENABLED=false to drop semantic FAQ.
# USE_GPT=false
# QWEN_MODEL=Qwen/Qwen3.5-397B-A17B
# QWEN_BASE_URL=https://api.together.xyz/v1
# QWEN_API_KEY=                 # Together AI key (TOGETHER_API_KEY also accepted)
# Optional cheaper Qwen for per-turn language detection (default = QWEN_MODEL):
# QWEN_LANG_DETECTOR_MODEL=Qwen/Qwen3.5-9B

# ── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8001
# Proxies trusted for X-Forwarded-* headers (uvicorn). Keep the default when
# nginx runs on the same host; never use "*" — it lets clients spoof their IP.
# FORWARDED_ALLOW_IPS=127.0.0.1

# ── Telegram Webhook ─────────────────────────────────────────────────────────
# Production: https://agent-bot.uz
# Leave empty for local long-polling mode
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=

# ── Chat Middleware (Asaka chat-middleware) — operator handoff ───────────────
# Реализация интеграции 1:1 с call_center_bot.
MIDDLEWARE_ENABLED=false
MIDDLEWARE_URL=https://chat-middleware-test-tm.asakabank.uz
MIDDLEWARE_LOGIN=telegram
MIDDLEWARE_PASSWORD=
# Передаётся в start-chat как isTestRequest=true/false
MIDDLEWARE_IS_TEST_REQUEST=true
# Если middleware на самоподписном сертификате — оставить false
MIDDLEWARE_VERIFY_SSL=false
# Опционально: URL через nginx reverse proxy (для WS)
# MIDDLEWARE_NGINX_WS_URL=

# Окно работы операторов (Asia/Tashkent по дефолту = +5)
MIDDLEWARE_WORKING_HOURS_ENABLED=false
MIDDLEWARE_WORKING_HOURS_START=8
MIDDLEWARE_WORKING_HOURS_END=23
MIDDLEWARE_WORKING_HOURS_TZ_OFFSET=5

# MinIO для пересылки медиа от пользователя оператору
# (POST {MINIO_BASE_URL}/api/chat/upload-file/, BasicAuth)
MINIO_BASE_URL=
MINIO_USERNAME=
MINIO_PASSWORD=

# ── Admin Panel (/admin) ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_SECRET_KEY=change-me-in-production

# ── LangGraph Checkpointing ─────────────────────────────────────────────────
LANGGRAPH_CHECKPOINT_BACKEND=auto
LANGGRAPH_CHECKPOINT_URL=
LANGGRAPH_DIALOG_TTL_MINUTES=1440

# ── Timeouts ─────────────────────────────────────────────────────────────────
SESSION_INACTIVITY_TIMEOUT_MINUTES=1440
HUMAN_MODE_OPERATOR_TIMEOUT_MINUTES=10
# Token budget for dialog history sent to the LLM (approximate count).
# Older messages are trimmed when the budget is exceeded.
MAX_DIALOG_TOKENS=3000

# Per-turn timeout for the agent invocation (seconds)
AGENT_TIMEOUT_SECONDS=25
# Per-request timeout for the main LLM (seconds)
OPENAI_REQUEST_TIMEOUT=15
# Per-request timeout for the language detector (seconds)
LANG_DETECTOR_TIMEOUT=10
# Retries for all OpenAI calls
OPENAI_MAX_RETRIES=1
# Max output tokens for the main agent LLM (default 3000).
# For non-reasoning models this is just a cap; they stop when done.
# Reasoning models (e.g. openai/gpt-oss-20b) share this budget between their
# analysis and final channels — 512 was too small for the final answer to fit.
# extract_text_content() strips harmony/reasoning channel markers automatically,
# so reasoning models work but waste tokens; prefer a non-reasoning instruct model.
# LLM_MAX_TOKENS=3000

# Language detector — separate small LLM call per user turn to detect ru/en/uz.
# Default is gpt-4o-mini regardless of OPENAI_MODEL (we want it cheap & fast).
# LANG_DETECTOR_MODEL=gpt-4o-mini
# Max output tokens for the language detector (default 512).
# Reasoning models need room beyond the final answer token (ru/en/uz);
# on a reasoning model 5 tokens is consumed entirely by the analysis channel.
# LANG_DETECTOR_MAX_TOKENS=512

# ── LangGraph persistence guard ──────────────────────────────────────────────
# Set to "true" in prod/k8s to fail fast at startup (and return 503 from /health)
# if the checkpointer resolves to MemorySaver instead of Postgres.
# REQUIRE_PERSISTENT_CHECKPOINTER=false

# ── Calculator defaults ──────────────────────────────────────────────────────
# Conservative interest rate used by the calculator when a product-specific
# rate is unavailable.
# DEFAULT_CUSTOM_LOAN_RATE_PCT=20.0

# ── FAQ semantic search (pgvector embeddings) ────────────────────────────────
# Requires the pgvector extension (docker-compose uses pgvector/pgvector:pg16).
# Embeddings are recomputed automatically when FAQ rows change (app/db/events.py).
# FAQ_EMBEDDING_ENABLED=true
# FAQ_EMBEDDING_MODEL=text-embedding-3-small
# FAQ_EMBEDDING_DIM=1536

# ── FAQ similarity thresholds ────────────────────────────────────────────────
# Per-leg tri-tier confidence: each leg (semantic = embedding cosine, lexical =
# difflib/token overlap) maps its score to strict / low / none against its own
# pair — the scales are different, a shared threshold can't fit both.
#   strict → return answer; low → FAQ_LOW_CONFIDENCE + closest FAQ questions
#   (LLM re-queries or treats as no match); none → NO_MATCH_IN_FAQ
# Legacy FAQ_STRICT_THRESHOLD / FAQ_LOW_CONFIDENCE_THRESHOLD are ignored.
# FAQ_SEM_STRICT_THRESHOLD=0.60
# FAQ_SEM_LOW_THRESHOLD=0.45
# FAQ_LEX_STRICT_THRESHOLD=0.75
# FAQ_LEX_LOW_THRESHOLD=0.55
# How many semantic candidates to surface on low confidence.
# FAQ_SEM_TOP_K=3