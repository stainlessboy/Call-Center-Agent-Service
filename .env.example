# ==============================================================================
#  agent-bot.uz — Environment Variables
# ==============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
BOT_TOKEN=
OPENAI_API_KEY=
ADMIN_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev:   postgresql+asyncpg://bankbot:bankbot@localhost:5432/bankbot
# Production:  postgresql+asyncpg://bankbot:bankbot@db:5432/bankbot
#              (overridden in docker-compose.prod.yml, no need to change)
DATABASE_URL=postgresql+asyncpg://bankbot:bankbot@localhost:5432/bankbot
POSTGRES_USER=bankbot
POSTGRES_PASSWORD=bankbot
POSTGRES_DB=bankbot

# ── OpenAI / LLM ────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # custom OpenAI-compatible endpoint
# LOCAL_AGENT_INTENT_LLM_MODEL= # override model for agent

# ── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8001

# ── Telegram Webhook ─────────────────────────────────────────────────────────
# Production: https://agent-bot.uz
# Leave empty for local long-polling mode
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=

# ── Chat Middleware (Asaka chat-middleware) — operator handoff ───────────────
# Реализация интеграции 1:1 с call_center_bot.
MIDDLEWARE_ENABLED=false
MIDDLEWARE_URL=https://chat-middleware-test-tm.asakabank.uz
MIDDLEWARE_LOGIN=telegram
MIDDLEWARE_PASSWORD=
# Передаётся в start-chat как isTestRequest=true/false
MIDDLEWARE_IS_TEST_REQUEST=true
# Если middleware на самоподписном сертификате — оставить false
MIDDLEWARE_VERIFY_SSL=false
# Опционально: URL через nginx reverse proxy (для WS)
# MIDDLEWARE_NGINX_WS_URL=

# Окно работы операторов (Asia/Tashkent по дефолту = +5)
MIDDLEWARE_WORKING_HOURS_ENABLED=false
MIDDLEWARE_WORKING_HOURS_START=8
MIDDLEWARE_WORKING_HOURS_END=23
MIDDLEWARE_WORKING_HOURS_TZ_OFFSET=5

# MinIO для пересылки медиа от пользователя оператору
# (POST {MINIO_BASE_URL}/api/chat/upload-file/, BasicAuth)
MINIO_BASE_URL=
MINIO_USERNAME=
MINIO_PASSWORD=

# ── Admin Panel (/admin) ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_SECRET_KEY=change-me-in-production

# ── LangGraph Checkpointing ─────────────────────────────────────────────────
LANGGRAPH_CHECKPOINT_BACKEND=auto
LANGGRAPH_CHECKPOINT_URL=
LANGGRAPH_DIALOG_TTL_MINUTES=1440

# ── Timeouts ─────────────────────────────────────────────────────────────────
SESSION_INACTIVITY_TIMEOUT_MINUTES=1440
HUMAN_MODE_OPERATOR_TIMEOUT_MINUTES=10
MAX_DIALOG_MESSAGES=12

# Per-turn timeout for the agent invocation (seconds)
AGENT_TIMEOUT_SECONDS=25
# Per-request timeout for the main LLM (seconds)
OPENAI_REQUEST_TIMEOUT=15
# Per-request timeout for the language detector (seconds)
LANG_DETECTOR_TIMEOUT=10
# Retries for all OpenAI calls
OPENAI_MAX_RETRIES=1

# Language detector — separate small LLM call per user turn to detect ru/en/uz.
# Default is gpt-4o-mini regardless of OPENAI_MODEL (we want it cheap & fast).
# LANG_DETECTOR_MODEL=gpt-4o-mini

# ── LangGraph persistence guard ──────────────────────────────────────────────
# Set to "true" in prod/k8s to fail fast at startup (and return 503 from /health)
# if the checkpointer resolves to MemorySaver instead of Postgres.
# REQUIRE_PERSISTENT_CHECKPOINTER=false

# ── Calculator defaults ──────────────────────────────────────────────────────
# Conservative interest rate used by the calculator when a product-specific
# rate is unavailable.
# DEFAULT_CUSTOM_LOAN_RATE_PCT=20.0