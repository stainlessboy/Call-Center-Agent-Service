# ==============================================================================
#  agent-bot.uz — Environment Variables
# ==============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
BOT_TOKEN=
OPENAI_API_KEY=
ADMIN_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev:   postgresql+asyncpg://bankbot:bankbot@localhost:5432/bankbot
# Production:  postgresql+asyncpg://bankbot:bankbot@db:5432/bankbot
#              (overridden in docker-compose.prod.yml, no need to change)
DATABASE_URL=postgresql+asyncpg://bankbot:bankbot@localhost:5432/bankbot
POSTGRES_USER=bankbot
POSTGRES_PASSWORD=bankbot
POSTGRES_DB=bankbot

# ── OpenAI / LLM ────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # custom OpenAI-compatible endpoint
# LOCAL_AGENT_INTENT_LLM_MODEL= # override model for agent

# ── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8001

# ── Telegram Webhook ─────────────────────────────────────────────────────────
# Production: https://agent-bot.uz
# Leave empty for local long-polling mode
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=

# ── Chat Middleware (Cisco UCCX) — operator handoff ──────────────────────────
# Set MIDDLEWARE_ENABLED=true to use Chat Middleware for operator handoff
MIDDLEWARE_ENABLED=false
MIDDLEWARE_URL=
MIDDLEWARE_LOGIN=
MIDDLEWARE_PASSWORD=
MIDDLEWARE_CSQ=Chat_Queue_1
# MIDDLEWARE_NGINX_WS_URL=        # optional: URL via nginx reverse proxy

# ── Admin Panel (/admin) ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_SECRET_KEY=change-me-in-production

# ── LangGraph Checkpointing ─────────────────────────────────────────────────
LANGGRAPH_CHECKPOINT_BACKEND=auto
LANGGRAPH_CHECKPOINT_URL=
LANGGRAPH_DIALOG_TTL_MINUTES=1440

# ── Timeouts ─────────────────────────────────────────────────────────────────
SESSION_INACTIVITY_TIMEOUT_MINUTES=1440
HUMAN_MODE_OPERATOR_TIMEOUT_MINUTES=10
MAX_DIALOG_MESSAGES=12