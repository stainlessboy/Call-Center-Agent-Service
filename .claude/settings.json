{
  "permissions": {
    "allow": [
      "Bash(alembic:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python3 -m py_compile:*)",
      "Bash(python3 -c:*)",
      "Bash(python -c:*)",
      "Bash(python -m pytest:*)",
      "Bash(pip:*)",
      "Bash(docker:*)",
      "Bash(curl:*)",
      "Bash(lsof:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(gtimeout:*)",
      "Bash(python3 main.py:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_close",
      "Bash(curl -s -o /tmp/conf_check.json -w \"HTTP %{http_code}\\\\n\" -H \"Authorization: Bearer REDACTED\" \"https://wiki.asakabank.uz/rest/api/user/current\"; echo \"---\"; cat /tmp/conf_check.json)",
      "Read(//tmp/**)",
      "Bash(command -v mcp-atlassian)",
      "Bash(command -v claude)",
      "Bash(pip3 install *)",
      "Bash(grep -n \"CONFLUENCE_URL\\\\|CONFLUENCE_PERSONAL_TOKEN\" ~/.zshrc 2>/dev/null || echo \"No existing CONFLUENCE entries in ~/.zshrc\")",
      "Read(//Users/user/**)",
      "Bash(cat >> *)",
      "Bash(claude mcp *)",
      "Bash(export CONFLUENCE_URL='https://wiki.asakabank.uz')",
      "Bash(export CONFLUENCE_PERSONAL_TOKEN='REDACTED')",
      "mcp__atlassian__confluence_search",
      "mcp__atlassian__confluence_get_space_page_tree",
      "mcp__atlassian__confluence_get_page",
      "mcp__atlassian__confluence_create_page",
      "mcp__atlassian__confluence_update_page"
    ],
    "additionalDirectories": [
      "/Users/user/.claude/projects/-Users-user-PycharmProjects-complex-agent-api/memory",
      "/Users/user"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -q '\\.py\"'; then echo 'Python file edit - will syntax check after'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo \"$TOOL_INPUT\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('file_path',''))\" 2>/dev/null); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -q '\\.py$'; then python3 -m py_compile \"$FILE\" 2>&1 || echo \"SYNTAX ERROR in $FILE\"; fi"
          }
        ]
      }
    ]
  }
}
